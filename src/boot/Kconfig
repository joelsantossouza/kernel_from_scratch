# =============================================================================
# MBR CONFIGURATION
# =============================================================================

menu "MBR Configuration"

# --------------------------------------
# Partition0
# --------------------------------------
	config MBR_PART0_BOOT_ATTR
		hex
		default 0x80 if DISK_PART0_BOOTABLE
		default 0x0

	config MBR_PART0_TYPECODE
		hex
		default 0x0E if DISK_PART0_FS_FAT16_LBA
		default 0x0
		
# --------------------------------------
# Partition1
# --------------------------------------
	config MBR_PART1_BOOT_ATTR
		hex
		default 0x80 if DISK_PART1_BOOTABLE
		default 0x0

	config MBR_PART1_TYPECODE
		hex
		default 0x0E if DISK_PART1_FS_FAT16_LBA
		default 0x0
		
# --------------------------------------
# Partition2
# --------------------------------------
	config MBR_PART2_BOOT_ATTR
		hex
		default 0x80 if DISK_PART2_BOOTABLE
		default 0x0

	config MBR_PART2_TYPECODE
		hex
		default 0x0E if DISK_PART2_FS_FAT16_LBA
		default 0x0
		
# --------------------------------------
# Partition3
# --------------------------------------
	config MBR_PART3_BOOT_ATTR
		hex
		default 0x80 if DISK_PART3_BOOTABLE
		default 0x0

	config MBR_PART3_TYPECODE
		hex
		default 0x0E if DISK_PART3_FS_FAT16_LBA
		default 0x0

endmenu

# =============================================================================
# BOOTLOADER CONFIGURATION
# =============================================================================

menu "Bootloader Configuration"

	config BOOT_STAGE2_ADDR
		hex "Address to Load Bootloader"
		range 0x7E00 0x7FFFF
		default 0x7E00

	config BOOT_STAGE2_SECTORS
		int "Bootloader Total Sectors"
		range 1 127
		default 20

	config BOOT_STAGE2_SECTOR
		int "Bootloader Disk LBA"
		range 2 63
		default 2

	config BOOT_STAGE2_CYLINDER
		int "Bootloader Disk CHS Cylinder"
		range 0 1023
		default 0

	config BOOT_STAGE2_HEAD
		int "Bootloader Disk CHS Head"
		range 0 255
		default 0

endmenu
