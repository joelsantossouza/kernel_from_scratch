# =============================================================================
# DISK DRIVERS
# =============================================================================
ROOT		:= $(shell git rev-parse --show-toplevel)

include $(ROOT)/config.mk

ATA_OBJS	:= ata/disk_ata.c.o

OBJS		:= $(ATA_OBJS)
C_OBJS		:= $(filter %.c.o, $(OBJS))

.PHONY: all fclean

all: $(OBJS)

# =============================================================================
# Disk Drivers Build
# =============================================================================

C_DEPS		:= $(C_OBJS:.o=.d)
-include	$(C_DEPS)
%.c.o: %.c
	$(CC) $(CFLAGS) $(INCLUDES) -MMD -MP -c $< -o $@

# =============================================================================
# Clean up
# =============================================================================

fclean:
	rm -f $(OBJS)
	rm -f $(C_DEPS)

re: fclean all
