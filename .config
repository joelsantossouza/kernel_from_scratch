
#
# Disk Configuration
#
CONFIG_DISK_SECTORS=0x10000
# end of Disk Configuration

#
# Partition Configuration
#
CONFIG_DISK_PART0_START=0x800
CONFIG_DISK_PART0_END=0x4600
# CONFIG_DISK_PART0_BOOTABLE is not set
CONFIG_DISK_PART0_FS_FAT16_LBA=y
CONFIG_DISK_PART0_FS_FAMILY="fat"
CONFIG_DISK_PART0_FS_VERSION=16
CONFIG_DISK_PART1_START=0x4600
CONFIG_DISK_PART1_END=0x8400
# CONFIG_DISK_PART1_BOOTABLE is not set
CONFIG_DISK_PART1_FS_FAT16_LBA=y
CONFIG_DISK_PART1_FS_FAMILY="fat"
CONFIG_DISK_PART1_FS_VERSION=16
CONFIG_DISK_PART2_START=0x8400
CONFIG_DISK_PART2_END=0xC200
# CONFIG_DISK_PART2_BOOTABLE is not set
CONFIG_DISK_PART2_FS_FAT16_LBA=y
CONFIG_DISK_PART2_FS_FAMILY="fat"
CONFIG_DISK_PART2_FS_VERSION=16
CONFIG_DISK_PART3_START=0xC200
CONFIG_DISK_PART3_END=0x10000
# CONFIG_DISK_PART3_BOOTABLE is not set
CONFIG_DISK_PART3_FS_FAT16_LBA=y
CONFIG_DISK_PART3_FS_FAMILY="fat"
CONFIG_DISK_PART3_FS_VERSION=16
# end of Partition Configuration

#
# MBR Configuration
#
CONFIG_MBR_PART0_BOOT_ATTR=0x0
CONFIG_MBR_PART0_TYPECODE=0x0
# end of MBR Configuration

#
# Bootloader Configuration
#
CONFIG_BOOT_STAGE2_ADDR=0x7E00
CONFIG_BOOT_STAGE2_SECTORS=20
CONFIG_BOOT_STAGE2_SECTOR=2
CONFIG_BOOT_STAGE2_CYLINDER=0
CONFIG_BOOT_STAGE2_HEAD=0
# end of Bootloader Configuration
